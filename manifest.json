{
  "manifest_version": 3,
  "name": "Smart AI Autofill Pro",
  "version": "2.0",

  "permissions": ["activeTab", "scripting", "storage"],

  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}