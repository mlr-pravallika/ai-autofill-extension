{
  "manifest_version": 3,
  "name": "Smart AI Autofill Pro",
  "version": "2.0",
  "description": "Auto fills forms intelligently",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}